NODE_ENV=development
PORT=5000
LOG_LEVEL=info
APP_NAME=CareCore HMS

DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
DATABASE_SSL=true

REDIS_URL=redis://localhost:6379

BCRYPT_ROUNDS=12

JWT_ACCESS_SECRET=replace_with_a_long_random_string
JWT_REFRESH_SECRET=replace_with_a_different_long_random_string
JWT_TWO_FACTOR_SECRET=replace_with_another_long_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_TOKEN_DAYS=7
JWT_TWO_FACTOR_EXPIRES_IN=5m

MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15
OTP_EXPIRY_MINUTES=10

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=CareCore HMS <no-reply@carecore.local>

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=
R2_PUBLIC_URL=

UPLOAD_MAX_FILE_SIZE_MB=10

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

MEDICINE_EXPIRY_ALERT_DAYS=30

AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Demo seed credentials (used by: npm run seed) ─────────────────────────────
# Set SEED_RESET=true to wipe all demo data and reseed from scratch.

SEED_RESET=false

